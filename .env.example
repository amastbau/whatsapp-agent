# Google Calendar OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=primary

# GCP project for Vertex AI (Claude API)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-east5

# Agent settings
DIGEST_TIME=21:00
CONFIDENCE_THRESHOLD=0.7
DB_PATH=./data/messages.db
